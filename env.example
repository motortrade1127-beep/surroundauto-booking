<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1400 980" role="img" aria-labelledby="title desc">
  <title id="title">Surround Auto logo</title>
  <desc id="desc">Stacked automotive logo with wrench, car roofline, spray gun, and the words Surround Auto.</desc>
  <defs>
    <linearGradient id="blue" x1="0" x2="1" y1="0" y2="1">
      <stop offset="0" stop-color="#0c78c7"/>
      <stop offset="1" stop-color="#075fa6"/>
    </linearGradient>
    <linearGradient id="blue-dark" x1="0" x2="1" y1="0" y2="1">
      <stop offset="0" stop-color="#0b70b8"/>
      <stop offset="1" stop-color="#045392"/>
    </linearGradient>
  </defs>

