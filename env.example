    <path d="M1181 434c33 18 61 40 86 66 12 13 28 10 38-3l54-68-46-38-66 59c-22-7-44-13-66-16Z" stroke-width="3"/>
    <path d="M1216 313l91-40 28 63-84 52-35-75Z" stroke-width="3"/>
